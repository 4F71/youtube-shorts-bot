# ============================================================
# YouTube Shorts Viral Bot — Çevre Değişkenleri
# Kopyala: cp .env.example .env  →  kendi değerlerini gir
# ============================================================

# Groq AI — Türkçe script üretimi (ücretsiz tier mevcut)
# https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here

# ElevenLabs TTS — Türkçe seslendirme
# https://elevenlabs.io
ELEVENLABS_API_KEY=sk_your_api_key_here
# Ses ID: ElevenLabs panelinden kopyala
ELEVENLABS_VOICE_ID=your_voice_id_here

# Instagram — scraping için giriş bilgileri
INSTAGRAM_USERNAME=your_username
INSTAGRAM_PASSWORD=your_password

# YouTube API (opsiyonel — upload için)
# https://console.cloud.google.com
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret

# Telegram bildirimleri (opsiyonel)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
